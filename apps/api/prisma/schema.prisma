generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

enum ConversationStatus {
  nova
  atendida_ia
  na_fila
  atendida_humano
  encerrada
}

enum OwnerType {
  ai
  agent
  queue
  none
}

enum MessageDirection {
  inbound
  outbound
}

enum MessageType {
  text
  image
  audio
  video
  document
  sticker
  location
  contact
}

enum MessageSender {
  customer
  ai
  agent
  system
}

enum AgentRole {
  admin
  supervisor
  attendant
}

enum AgentAvailability {
  online
  away
  offline
}

model Conversation {
  id                  String             @id @default(uuid())
  externalPhone       String             @map("external_phone")
  instanceId          String             @map("instance_id")
  status              ConversationStatus @default(nova)
  ownerType           OwnerType          @default(none) @map("owner_type")
  agentId             String?            @map("agent_id")
  version             Int                @default(1)
  metadata            Json?
  progressiveSummary  String?            @map("progressive_summary")
  finalSummary        String?            @map("final_summary")
  summaryMessageCount Int                @default(0) @map("summary_message_count")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")
  closedAt            DateTime?          @map("closed_at")

  agent    Agent?          @relation(fields: [agentId], references: [id])
  instance ChannelInstance @relation(fields: [instanceId], references: [id])
  messages Message[]

  @@index([externalPhone])
  @@index([status])
  @@index([agentId])
  @@index([instanceId])
  @@map("conversations")
}

model ChannelInstance {
  id            String   @id @default(uuid())
  name          String
  phone         String?
  instanceName  String   @unique @map("instance_name")
  serverUrl     String   @map("server_url")
  instanceToken String   @map("instance_token") // AES-256-GCM encrypted via CryptoService
  webhookSecret String   @map("webhook_secret")
  status        String   @default("disconnected")
  cdFilial      Int      @default(1) @map("cd_filial") // Filial do ERP Flex atendida por este número
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  conversations Conversation[]

  @@map("channel_instances")
}

model Message {
  id             String           @id @default(uuid())
  conversationId String           @map("conversation_id")
  externalId     String?          @unique @map("external_id")
  direction      MessageDirection
  type           MessageType      @default(text)
  sender         MessageSender
  content        String
  mediaUrl       String?          @map("media_url")
  metadata       Json?
  createdAt      DateTime         @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id])

  @@index([conversationId])
  @@map("messages")
}

model Agent {
  id            String            @id @default(uuid())
  name          String
  email         String            @unique
  role          AgentRole         @default(attendant)
  availability  AgentAvailability @default(offline)
  maxConcurrent Int               @default(5) @map("max_concurrent")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  conversations Conversation[]

  @@map("agents")
}

model MemoryEmbedding {
  id        String                     @id @default(uuid())
  phone     String
  content   String
  embedding Unsupported("vector(384)")
  createdAt DateTime                   @default(now()) @map("created_at")

  @@index([phone])
  @@map("memory_embeddings")
}

// Vínculo verificado telefone WhatsApp → Cliente Flex (cdCliente).
// Criado só após CPF/CNPJ + telefone baterem com o cadastro (anti-impersonação).
model IdentityBinding {
  id        String   @id @default(uuid())
  phone     String   @unique
  cdCliente Int      @map("cd_cliente")
  verified  Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("identity_bindings")
}
