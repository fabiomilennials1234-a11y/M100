# Supabase
DATABASE_URL="postgresql://postgres:postgres@db.xxxxx.supabase.co:5432/postgres"
VITE_SUPABASE_URL="https://xxxxx.supabase.co"
VITE_SUPABASE_ANON_KEY="eyJhbGci..."

# Redis (BullMQ)
REDIS_HOST="localhost"
REDIS_PORT="6379"

# UAZAPI
UAZAPI_BASE_URL="https://api.uazapi.com"
UAZAPI_TOKEN=""
UAZAPI_WEBHOOK_SECRET=""
# Fase 6 — multi-instance: server base (no instance path) + admin token
UAZAPI_SERVER_URL="https://api.uazapi.com"
UAZAPI_ADMIN_TOKEN=""
# Public base URL of this API, for per-instance webhook registration
API_PUBLIC_URL="https://api.motor100.app"

# Crypto — AES-256-GCM key for encrypting instance tokens at rest.
# 64 hex chars = 32 bytes. Generate: openssl rand -hex 32
ENCRYPTION_KEY=""

# OpenRouter
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="anthropic/claude-sonnet-4-20250514"

# Langfuse (tracing — opcional, desliga silenciosamente sem config)
LANGFUSE_PUBLIC_KEY=""
LANGFUSE_SECRET_KEY=""
LANGFUSE_HOST="https://cloud.langfuse.com"

# Rate Limiting
RATE_LIMIT_PER_MINUTE="30"

# Debounce
DEBOUNCE_TIMEOUT_MS="3000"

# API
PORT="3000"

# Flex Smart ERP (Fase 7) — consultas read-only
FLEX_BASE_URL="http://flex.local:8080"
FLEX_USERNAME=""
FLEX_PASSWORD=""
